{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro Backend Proxy",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "dummy-key-not-used-by-proxy"
      },
      "models": {
        "claude-opus-4-5": {
          "name": "Claude Opus 4.5 (via Kiro)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (via Kiro)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    },
    "zhipu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zhipu AI (GLM)",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "YOUR_ZHIPU_API_KEY_HERE"
      },
      "models": {
        "glm-4-plus": {
          "name": "GLM-4 Plus",
          "limit": {
            "context": 128000,
            "output": 4096
          }
        }
      }
    }
  }
}
